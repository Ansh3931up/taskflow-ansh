{
  "info": {
    "name": "TaskFlow API - Take Home Evaluation",
    "description": "Collection strictly mapped to the required Appendix endpoints for the TaskFlow application assessment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Jane Doe\",\n    \"email\": \"jane.doe@example.com\",\n    \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:4000/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:4000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }],
            "url": {
              "raw": "http://localhost:4000/projects",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["projects"]
            }
          }
        },
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Website Redesign\",\n    \"description\": \"Q2 project\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:4000/projects",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["projects"]
            }
          }
        },
        {
          "name": "Get Project (With Tasks)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }],
            "url": {
              "raw": "http://localhost:4000/projects/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["projects", ":id"],
              "variable": [{ "key": "id", "value": "replace-with-uuid" }]
            }
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Updated Name\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:4000/projects/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["projects", ":id"],
              "variable": [{ "key": "id", "value": "replace-with-uuid" }]
            }
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }],
            "url": {
              "raw": "http://localhost:4000/projects/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["projects", ":id"],
              "variable": [{ "key": "id", "value": "replace-with-uuid" }]
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List Tasks (Filtered)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }],
            "url": {
              "raw": "http://localhost:4000/projects/:id/tasks?status=todo",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["projects", ":id", "tasks"],
              "query": [{ "key": "status", "value": "todo" }],
              "variable": [{ "key": "id", "value": "replace-with-uuid" }]
            }
          }
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Design homepage\",\n    \"priority\": \"high\",\n    \"due_date\": \"2026-04-15\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:4000/projects/:id/tasks",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["projects", ":id", "tasks"],
              "variable": [{ "key": "id", "value": "replace-with-uuid" }]
            }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"done\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:4000/tasks/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["tasks", ":id"],
              "variable": [{ "key": "id", "value": "replace-with-uuid" }]
            }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }],
            "url": {
              "raw": "http://localhost:4000/tasks/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["tasks", ":id"],
              "variable": [{ "key": "id", "value": "replace-with-uuid" }]
            }
          }
        }
      ]
    }
  ]
}
