{
  "info": {
    "name": "TaskFlow - Take Home Evaluator API",
    "description": "Auto-configured workspace mapping the Mock Appendix. Dynamically saves authentication tokens and UUIDs into native collection variables for highly rapid testing flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "token", "value": "jwt-token-will-save-here-automatically", "type": "string" },
    { "key": "projectId", "value": "project-uuid-will-save-here-automatically", "type": "string" },
    { "key": "taskId", "value": "task-uuid-will-save-here-automatically", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Jane Doe\",\n    \"email\": \"jane.doe@example.com\",\n    \"password\": \"secret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:4000/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if(response.token) {",
                  "  pm.collectionVariables.set('token', response.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:4000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if(response.token) {",
                  "  pm.collectionVariables.set('token', response.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Projects API",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Website Redesign\",\n    \"description\": \"Q2 project\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:4000/projects",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["projects"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if(response.id) { pm.collectionVariables.set('projectId', response.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:4000/projects",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["projects"]
            }
          }
        },
        {
          "name": "Get Project (With Tasks)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:4000/projects/{{projectId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["projects", "{{projectId}}"]
            }
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Updated Website Name\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:4000/projects/{{projectId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["projects", "{{projectId}}"]
            }
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:4000/projects/{{projectId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["projects", "{{projectId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Tasks API",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Design homepage\",\n    \"priority\": \"high\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:4000/projects/{{projectId}}/tasks",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["projects", "{{projectId}}", "tasks"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if(response.id) { pm.collectionVariables.set('taskId', response.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List Tasks (Filtered)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:4000/projects/{{projectId}}/tasks?status=todo",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["projects", "{{projectId}}", "tasks"],
              "query": [{ "key": "status", "value": "todo" }]
            }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"status\": \"done\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:4000/tasks/{{taskId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["tasks", "{{taskId}}"]
            }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "http://localhost:4000/tasks/{{taskId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["tasks", "{{taskId}}"]
            }
          }
        }
      ]
    }
  ]
}
