# Optional: copy to `.env` to override Compose defaults (`cp .env.example .env`).
# `docker compose up` works without `.env` using the same values as defaults below.

# --- PostgreSQL (service `db` + backend) ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=taskflow

PORT=4000
NODE_ENV=development

# At least 10 characters. Override in any shared or production environment.
JWT_SECRET=development-only-change-for-production-min-10-chars

# Comma-separated origins for CORS (must match browser Origin exactly).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Browser-visible API URL when using the Docker-built frontend (host maps API to 4000).
VITE_API_URL=http://localhost:4000

# --- Local backend only (`npm run dev --workspace=backend` with Postgres on host) ---
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/taskflow
