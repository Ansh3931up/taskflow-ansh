{
  "name": "taskflow-ansh",
  "version": "1.0.0",
  "description": "TaskFlow-Ansh — monorepo root",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=backend\"",
    "prepare": "husky",
    "lint": "npm run lint --workspace=frontend",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.0"
  },
  "dependencies": {
    "date-fn": "^0.0.2"
  }
}
